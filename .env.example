# ======================
# PostgreSQL
# ======================
POSTGRES_DB=airdrophunter
POSTGRES_USER=airdrop_user
POSTGRES_PASSWORD=airdrop_secret_pass
POSTGRES_PORT=5432

# ======================
# Backend (Spring Boot)
# ======================
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/airdrophunter
SPRING_DATASOURCE_USERNAME=airdrop_user
SPRING_DATASOURCE_PASSWORD=airdrop_secret_pass
SERVER_PORT=8080

# ======================
# Frontend (Next.js)
# ======================
NEXT_PUBLIC_API_URL=http://localhost:8080

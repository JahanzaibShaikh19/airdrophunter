# ======================
# PostgreSQL
# ======================
POSTGRES_DB=airdrophunter
POSTGRES_USER=airdrop_user
POSTGRES_PASSWORD=airdrop_secret_pass
POSTGRES_PORT=5432

# ======================
# Backend (Spring Boot)
# ======================
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/airdrophunter
SPRING_DATASOURCE_USERNAME=airdrop_user
SPRING_DATASOURCE_PASSWORD=airdrop_secret_pass
SERVER_PORT=8080

# JWT & PRO Subscriptions
JWT_SECRET=generate_a_secure_random_base64_string_with_at_least_512_bits
JWT_EXPIRATION_MS=2592000000
GUMROAD_WEBHOOK_SECRET=your_gumroad_webhook_secret_here

# ======================
# Frontend (Next.js)
# ======================
NEXT_PUBLIC_API_URL=http://localhost:8080
